# Copy to backend/.env (never commit .env)
# https://console.groq.com/keys — preferred for /analyze + Q&A

GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
# Optional: smaller model for /ask chat only (fewer $ / tokens than a 120B). Example: llama-3.1-8b-instant
# GROQ_QA_MODEL=llama-3.1-8b-instant
# On-demand tier ~8k TPM: keep transcript + max_completion small (defaults: 12000 chars, 2048 tokens).
# GROQ_MAX_TRANSCRIPT_CHARS=12000
# Shorter context for Q&A than /analyze (default 8000 chars).
# GROQ_MAX_QA_TRANSCRIPT_CHARS=8000
# GROQ_MAX_TOKENS_ANALYZE=2048
# GROQ_MAX_TOKENS_QA=1024
# GROQ_ANALYZE=0
# GROQ_REASONING_EFFORT=medium
# GROQ_TEMPERATURE_ANALYZE=0.2
# GROQ_TEMPERATURE_QA=0.2
# GROQ_MAX_TOKENS_ANALYZE=8192
# GROQ_MAX_TOKENS_QA=2048

# Optional: Gemini if GROQ_API_KEY is unset (same JSON analyze contract)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash-001
# GEMINI_ANALYZE=1

# Offline / ablation: local BART + rules for /analyze (no LLM key)
# ALLOW_LOCAL_ANALYZE_WITHOUT_LLM=1
# (alias) ALLOW_LOCAL_ANALYZE_WITHOUT_GEMINI=1

# Optional: PostgreSQL
# DATABASE_URL=postgresql://user:pass@localhost:5432/meetingmind
